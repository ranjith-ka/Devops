{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Tutorial Agent HTTP Server",
      "type": "shell",
      "command": "go run ./agents/tutorial_agent",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^.*$",
            "file": 0,
            "location": 1,
            "message": 2
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*",
          "endsPattern": "Tutorial Agent running on"
        }
      }
    }
  ]
}
